# ===== ears 配置 =====
# 必填：Groq key（转写+情绪判断都用它，免费）。注册: https://console.groq.com
GROQ_API_KEY=

# 国内需要代理才能连Groq。填你的代理端口，常见:
#   Clash: http://127.0.0.1:7890    v2rayN: http://127.0.0.1:10809
PROXY=

# 选填：每次分析完把结果POST到这个地址，接你自己的AI（不填就只在网页看）
WEBHOOK=

# 选填：情绪标签，逗号分隔，按你们的相处方式随便改
EMOTIONS=开心,兴奋,撒娇,平静,累,低落,委屈,生气,嘴硬,紧张

# 选填：数据目录（记录+基线）。多人各跑一个实例时指到不同目录
DATA=

# 选填：留存录音（默认阅后即焚）
KEEP_AUDIO=0

# 高级：换别的转写/LLM服务（OpenAI兼容接口都行）
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile
# ASR_MODEL=whisper-large-v3
